# =============================================================================
# Carbide Provider Node Environment Configuration
# These override values from ~/.carbide/config/provider.toml
# =============================================================================

# --- Provider ---
CARBIDE_PROVIDER_NAME=my-carbide-provider
CARBIDE_PROVIDER_PORT=8080
CARBIDE_PROVIDER_TIER=home
CARBIDE_PROVIDER_REGION=northamerica
CARBIDE_STORAGE_PATH=/data/storage
CARBIDE_MAX_STORAGE_GB=25

# --- Network ---
CARBIDE_DISCOVERY_ENDPOINT=https://discovery.carbidenetwork.xyz
CARBIDE_ADVERTISE_ADDRESS=127.0.0.1:8080
CARBIDE_HEARTBEAT_INTERVAL=60

# --- Pricing ---
CARBIDE_PRICE_PER_GB=0.005

# --- Authentication ---
CARBIDE_AUTH_ENABLED=false
CARBIDE_AUTH_JWT_SECRET=

# --- TLS ---
CARBIDE_TLS_ENABLED=false
CARBIDE_TLS_CERT_PATH=certs/server.crt
CARBIDE_TLS_KEY_PATH=certs/server.key
CARBIDE_TLS_AUTO_GENERATE=true

# --- Blockchain ---
CARBIDE_CHAIN_ID=421614
CARBIDE_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
CARBIDE_ESCROW_ADDRESS=
CARBIDE_USDC_ADDRESS=
CARBIDE_WALLET_PATH=

# --- Proof Scheduler ---
CARBIDE_PROOF_INTERVAL=21600
CARBIDE_PROOF_CHALLENGE_PCT=0.1

# --- Logging ---
CARBIDE_LOG_LEVEL=info
CARBIDE_LOG_FORMAT=text
